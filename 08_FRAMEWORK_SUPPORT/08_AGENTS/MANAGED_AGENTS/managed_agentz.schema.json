{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emergentism.invalid/schemas/managed-agentz-1.0.json",
  "title": "Managed Agentz control-plane records",
  "description": "Closed structural schemas. Cross-record set, hash, time, scope, and issuer invariants are enforced by contract.py.",
  "$defs": {
    "StringId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "StringIdArray": {
      "type": "array",
      "items": {"$ref": "#/$defs/StringId"},
      "uniqueItems": true
    },
    "Sha256Hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "SchnorrSignatureHex": {
      "type": "string",
      "pattern": "^[0-9a-f]{128}$"
    },
    "RepositoryPathArray": {
      "type": "array",
      "items": {"$ref": "#/$defs/StringId"},
      "uniqueItems": true
    },
    "ActionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "planId", "summary", "repository", "repositoryRef",
        "operations", "requestedPaths"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "planId": {"$ref": "#/$defs/StringId"},
        "summary": {"$ref": "#/$defs/StringId"},
        "repository": {"$ref": "#/$defs/StringId"},
        "repositoryRef": {"$ref": "#/$defs/StringId"},
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["read", "grep", "glob", "web_search", "web_fetch", "write", "edit", "bash"]
          }
        },
        "requestedPaths": {"$ref": "#/$defs/RepositoryPathArray"}
      }
    },
    "TrustPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "policyId", "authorizationSigners", "deploymentVerifiers",
        "maxAuthorizationAgeSeconds", "maxDeploymentAgeSeconds", "maxFutureSkewSeconds"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "policyId": {"$ref": "#/$defs/StringId"},
        "authorizationSigners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["keyId", "publicKeyHex", "principalIds"],
            "properties": {
              "keyId": {"$ref": "#/$defs/StringId"},
              "publicKeyHex": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "principalIds": {
                "allOf": [{"$ref": "#/$defs/StringIdArray"}, {"minItems": 1}]
              }
            }
          }
        },
        "deploymentVerifiers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["keyId", "publicKeyHex", "verifierIds"],
            "properties": {
              "keyId": {"$ref": "#/$defs/StringId"},
              "publicKeyHex": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "verifierIds": {
                "allOf": [{"$ref": "#/$defs/StringIdArray"}, {"minItems": 1}]
              }
            }
          }
        },
        "maxAuthorizationAgeSeconds": {"type": "integer", "minimum": 1},
        "maxDeploymentAgeSeconds": {"type": "integer", "minimum": 1},
        "maxFutureSkewSeconds": {"type": "integer", "minimum": 0}
      }
    },
    "BudgetEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxCalls", "maxTokens", "maxWallSeconds", "maxDelegations"],
      "properties": {
        "maxCalls": {"type": "integer", "minimum": 1},
        "maxTokens": {"type": "integer", "minimum": 1},
        "maxWallSeconds": {"type": "integer", "minimum": 1},
        "maxDelegations": {"type": "integer", "minimum": 0}
      }
    },
    "EvaluationContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "blind", "rivals"],
      "properties": {
        "contract": {"const": "blinded_budget_matched_against_flat_and_shorter_rivals"},
        "blind": {"const": true},
        "rivals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/StringId"}
        }
      }
    },
    "AuthorizationEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "envelopeId", "actionPlanSha256", "principal", "mandate", "scope",
        "consent", "custody", "issuedAt", "expiresAt", "revoked", "contestPath", "actor",
        "consequenceBearerIds", "payerIds", "beneficiaryIds", "expectedBearerDeltas",
        "signerKeyId", "signature"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "envelopeId": {"$ref": "#/$defs/StringId"},
        "actionPlanSha256": {"$ref": "#/$defs/Sha256Hex"},
        "principal": {"$ref": "#/$defs/StringId"},
        "mandate": {"$ref": "#/$defs/StringId"},
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "repositoryRef", "allowedPaths", "allowedOperations"],
          "properties": {
            "repository": {"$ref": "#/$defs/StringId"},
            "repositoryRef": {"$ref": "#/$defs/StringId"},
            "allowedPaths": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/StringId"}
            },
            "allowedOperations": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": ["read", "grep", "glob", "web_search", "web_fetch", "write", "edit", "bash"]
              }
            }
          }
        },
        "consent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "grantedBy", "grantedAt"],
          "properties": {
            "status": {"const": "granted"},
            "grantedBy": {"$ref": "#/$defs/StringId"},
            "grantedAt": {"type": "string", "format": "date-time"}
          }
        },
        "custody": {"$ref": "#/$defs/StringId"},
        "issuedAt": {"type": "string", "format": "date-time"},
        "expiresAt": {"type": "string", "format": "date-time"},
        "revoked": {"const": false},
        "contestPath": {"$ref": "#/$defs/StringId"},
        "actor": {"$ref": "#/$defs/StringId"},
        "consequenceBearerIds": {
          "allOf": [{"$ref": "#/$defs/StringIdArray"}, {"minItems": 1}]
        },
        "payerIds": {"$ref": "#/$defs/StringIdArray"},
        "beneficiaryIds": {"$ref": "#/$defs/StringIdArray"},
        "expectedBearerDeltas": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"type": "number"}
        },
        "signerKeyId": {"$ref": "#/$defs/StringId"},
        "signature": {"$ref": "#/$defs/SchnorrSignatureHex"}
      }
    },
    "AuthorizationAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "envelopeSha256", "reasons"],
      "properties": {
        "status": {"enum": ["valid", "invalid", "expired", "revoked", "out_of_scope"]},
        "envelopeSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "reasons": {"$ref": "#/$defs/StringIdArray"}
      }
    },
    "RunRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "requestId", "task", "consequential", "operations",
        "repository", "repositoryRef", "actionPlan", "actionPlanSha256",
        "budget", "evaluation", "authorization"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "requestId": {"$ref": "#/$defs/StringId"},
        "task": {"$ref": "#/$defs/StringId"},
        "consequential": {"type": "boolean"},
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["read", "grep", "glob", "web_search", "web_fetch", "write", "edit", "bash"]
          }
        },
        "repository": {"$ref": "#/$defs/StringId"},
        "repositoryRef": {"$ref": "#/$defs/StringId"},
        "actionPlan": {"$ref": "#/$defs/ActionPlan"},
        "actionPlanSha256": {"$ref": "#/$defs/Sha256Hex"},
        "budget": {"$ref": "#/$defs/BudgetEnvelope"},
        "evaluation": {"$ref": "#/$defs/EvaluationContract"},
        "authorization": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/AuthorizationEnvelope"}]
        }
      }
    },
    "CommitmentReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "receiptType", "requestId", "actionId", "status",
        "authorizationAssessment", "actionPlanSha256", "budgetSha256",
        "deploymentSha256", "issuedBy"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "receiptType": {"const": "commitment"},
        "requestId": {"$ref": "#/$defs/StringId"},
        "actionId": {"type": ["string", "null"]},
        "status": {"enum": ["refused", "authorization_pending", "attempt_started", "attempt_failed"]},
        "authorizationAssessment": {"$ref": "#/$defs/AuthorizationAssessment"},
        "actionPlanSha256": {"$ref": "#/$defs/Sha256Hex"},
        "budgetSha256": {"$ref": "#/$defs/Sha256Hex"},
        "deploymentSha256": {"$ref": "#/$defs/Sha256Hex"},
        "issuedBy": {"$ref": "#/$defs/StringId"}
      }
    },
    "JusticeAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "justiceSatisfied", "bearerCoverageComplete", "focalIndividualId",
        "declaredWholeId", "focalBeneficiaryIds", "assessedBy", "reasons"
      ],
      "properties": {
        "status": {"enum": ["complete", "incomplete"]},
        "justiceSatisfied": {"type": ["boolean", "null"]},
        "bearerCoverageComplete": {"type": "boolean"},
        "focalIndividualId": {"type": ["string", "null"]},
        "declaredWholeId": {"type": ["string", "null"]},
        "focalBeneficiaryIds": {"$ref": "#/$defs/StringIdArray"},
        "assessedBy": {"type": ["string", "null"]},
        "reasons": {"$ref": "#/$defs/StringIdArray"}
      }
    },
    "OutcomeClassification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "demonBearing", "godBearing", "preservativeStasis", "strictSyntropy"
      ],
      "properties": {
        "status": {"enum": ["classified", "unclassified"]},
        "demonBearing": {"type": ["boolean", "null"]},
        "godBearing": {"type": ["boolean", "null"]},
        "preservativeStasis": {"type": ["boolean", "null"]},
        "strictSyntropy": {"type": ["boolean", "null"]}
      }
    },
    "OutcomeReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "receiptType", "receiptCause", "requestId", "actionId",
        "actionPlanSha256", "status", "consequenceBearerIds", "observedBearerDeltas",
        "justiceAssessment", "classification", "issuedBy"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "receiptType": {"const": "outcome"},
        "receiptCause": {"enum": ["action_attempt", "ambient_observation"]},
        "requestId": {"$ref": "#/$defs/StringId"},
        "actionId": {"type": ["string", "null"]},
        "actionPlanSha256": {"$ref": "#/$defs/Sha256Hex"},
        "status": {"enum": ["observed", "partial", "unobservable", "pending"]},
        "consequenceBearerIds": {"$ref": "#/$defs/StringIdArray"},
        "observedBearerDeltas": {
          "type": "object",
          "additionalProperties": {"type": ["number", "null"]}
        },
        "justiceAssessment": {"$ref": "#/$defs/JusticeAssessment"},
        "classification": {"$ref": "#/$defs/OutcomeClassification"},
        "issuedBy": {"$ref": "#/$defs/StringId"}
      }
    },
    "DeploymentReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "status", "bundleSha256", "environment", "agents",
        "topology", "verifiedAt", "verifier", "attestation"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "status": {"const": "remote_verified"},
        "bundleSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "configSha256"],
          "properties": {
            "id": {"$ref": "#/$defs/StringId"},
            "configSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "agents": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["level", "id", "version", "configSha256"],
            "properties": {
              "level": {"enum": ["L1", "L2", "L3", "L4", "L5", "L6", "L7"]},
              "id": {"$ref": "#/$defs/StringId"},
              "version": {"type": "integer", "minimum": 1},
              "configSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        },
        "topology": {
          "type": "object",
          "additionalProperties": false,
          "required": ["coordinator", "delegates", "selfDelegation"],
          "properties": {
            "coordinator": {"const": "L4"},
            "delegates": {
              "const": ["L1", "L2", "L3", "L5", "L6", "L7"]
            },
            "selfDelegation": {"const": true}
          }
        },
        "verifiedAt": {"type": "string", "format": "date-time"},
        "verifier": {"$ref": "#/$defs/StringId"},
        "attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["keyId", "signedAt", "signature"],
          "properties": {
            "keyId": {"$ref": "#/$defs/StringId"},
            "signedAt": {"type": "string", "format": "date-time"},
            "signature": {"$ref": "#/$defs/SchnorrSignatureHex"}
          }
        }
      }
    },
    "RunRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "requestSha256", "actionPlanSha256", "bundleSha256", "deploymentSha256",
        "commitmentReceiptSha256", "outcomeReceiptSha256", "budgetSha256"
      ],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "requestSha256": {"$ref": "#/$defs/Sha256Hex"},
        "actionPlanSha256": {"$ref": "#/$defs/Sha256Hex"},
        "bundleSha256": {"$ref": "#/$defs/Sha256Hex"},
        "deploymentSha256": {"$ref": "#/$defs/Sha256Hex"},
        "commitmentReceiptSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "outcomeReceiptSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "budgetSha256": {"$ref": "#/$defs/Sha256Hex"}
      }
    }
  }
}
