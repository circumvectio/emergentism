    { "source": "/suda-notes/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/game/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/atlas/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/soul-loop/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/sources/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] }
  ]
}
