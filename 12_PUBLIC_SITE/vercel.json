{
  "version": 2,
  "framework": null,
  "installCommand": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/home/", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https:; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; worker-src 'self'; manifest-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/vendor/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    { "source": "/papers/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/canon/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/foundations/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/trinity/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/formal/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/paradox/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/memetic/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/rosettad/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/rosetta/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/operators/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/will/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/value/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/ground/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/sacred/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/method/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/meta/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/axiology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/epistemology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/methodology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/cosmology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/ontology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/theology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/teleology/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
    { "source": "/dasein/(.*)", "headers": [{ "key": "X-Robots-Tag", "value": "noindex, follow" }] },
